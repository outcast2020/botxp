PORT=8787
TIMEZONE=America/Sao_Paulo
NODE_ENV=development
APP_MODE=trade
DRY_RUN=true

SYMBOL=DOGEUSDT
MARKET=usds_m_futures
TIMEFRAME=5m
HTF_TIMEFRAME=4h
INITIAL_CAPITAL_USDT=20
ORDER_BUDGET_USDT=7
DEFAULT_LEVERAGE=3
MAX_LEVERAGE=5
MARGIN_MODE=ISOLATED
POSITION_MODE=ONE_WAY

# segredo compartilhado para o emissor de sinais do seu terminal
SIGNAL_PASSPHRASE=CHANGE_ME
# compatibilidade legada com TradingView
TV_PASSPHRASE=
MAX_SIGNAL_AGE_MS=120000
MAX_ENTRIES_PER_DAY=6
DAILY_STOP_LOSS_USDT=1.5
MAX_CONSECUTIVE_LOSSES=3
DRY_RUN_FEE_RATE=0.0004

# live exige as duas variaveis abaixo; mantenha fora de frontend, Apps Script e Git
BINANCE_BASE_URL=https://fapi.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_RECV_WINDOW=5000

APPS_SCRIPT_SYNC_URL=
APPS_SCRIPT_SYNC_TOKEN=
APPS_SCRIPT_SYNC_TIMEOUT_MS=3500

POLYMARKET_ENABLED=true
# leitura publica somente: Gamma + CLOB publicos; nenhuma credencial da Polymarket e necessaria
POLYMARKET_EVENT_SLUG=what-price-will-wti-hit-in-april-2026
POLYMARKET_REFRESH_MS=60000
POLYMARKET_STALE_MS=90000
POLYMARKET_HARD_BLOCK_SCORE=0.9

POLICY_PROVIDER=openai
OPENAI_ENABLED=false
OPENAI_REQUIRED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# gpt-5-mini estica melhor um saldo pequeno; gpt-5.4-mini e a troca natural se voce quiser mais qualidade.
OPENAI_MODEL=gpt-5-mini
OPENAI_REFRESH_MS=300000
OPENAI_STALE_MS=900000
OPENAI_TIMEOUT_MS=6000
OPENAI_MAX_TOKENS=400
OPENAI_TEMPERATURE=0.1

BACKTEST_START=
BACKTEST_END=
BACKTEST_LOOKBACK_DAYS=21
BACKTEST_WARMUP_BARS=600
BACKTEST_DATASET_FORWARD_BARS=15
BACKTEST_OUTPUT_PREFIX=backtest
BACKTEST_SIDE_MODE=BOTH
BACKTEST_SESSION_FILTER=OFF
BACKTEST_SESSION_START_HOUR=9
BACKTEST_SESSION_END_HOUR=18
BACKTEST_VOLUME_LOOKBACK=20
BACKTEST_MIN_VOLUME_RATIO=0.95
BACKTEST_MIN_BODY_PCT=0.08
BACKTEST_MIN_HTF_FAST_SLOW_GAP_PCT=0.12
BACKTEST_MIN_HTF_CLOSE_BASE_GAP_PCT=0.25
BACKTEST_MIN_LTF_FAST_SLOW_GAP_PCT=0.05
BACKTEST_MIN_LTF_SLOW_TREND_GAP_PCT=0.10
BACKTEST_MIN_HTF_RSI_BULL=55
BACKTEST_MAX_HTF_RSI_BEAR=45
BACKTEST_LONG_RSI_BUFFER=4
BACKTEST_SHORT_RSI_BUFFER=4
BACKTEST_REQUIRE_TREND_CANDLE=true
